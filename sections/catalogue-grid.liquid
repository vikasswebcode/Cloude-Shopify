
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="koc-catalogue section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{%- render 'spacing-padding', settings: section.settings -%}"
>
  {%- if section.settings.heading != blank -%}
    <div class="koc-catalogue__header">
      <h2 class="koc-catalogue__heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="koc-catalogue__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}  

  <div class="koc-catalogue__grid">
    {%- for block in section.blocks -%}
      <div class="koc-catalogue__card" {{ block.shopify_attributes }}>
        <div class="koc-catalogue__media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                class: 'koc-catalogue__img',
                widths: '400, 600, 800',
                sizes: '(max-width:749px) 50vw, 25vw',
                alt: block.settings.title
            }}
          {%- else -%}
            {{ 'collection-apparel-' | append: forloop.index | placeholder_svg_tag: 'koc-catalogue__img koc-catalogue__placeholder' }}
          {%- endif -%}
          <div class="koc-catalogue__overlay"></div>
        </div>
        <div class="koc-catalogue__content">
          {%- if block.settings.title != blank -%}
            <h3 class="koc-catalogue__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.subtitle != blank -%}
            <p class="koc-catalogue__subtitle">{{ block.settings.subtitle | escape }}</p>
          {%- endif -%}
          {%- if block.settings.btn_label != blank and block.settings.link != blank -%}
            <a
              href="{{ block.settings.link }}"
              class="koc-catalogue__btn koc-catalogue__btn--{{ block.settings.btn_style }}"
              target="_blank"
              rel="noopener noreferrer"
            >{{ block.settings.btn_label | escape }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.koc-catalogue__header {
  text-align: center;
  margin-bottom: 36px;
}

.koc-catalogue__heading {
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 700;
  margin-bottom: 10px;
}

.koc-catalogue__subheading {
  font-size: 0.9rem;
  opacity: 0.65;
}

.koc-catalogue__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}

@media screen and (min-width: 750px) {
  .koc-catalogue__grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
}

.koc-catalogue__card {
  position: relative;
  border-radius: 14px;
  overflow: hidden;
  height: 200px;
  background: #c9a050;
  cursor: pointer;
}

@media screen and (min-width: 750px) {
  .koc-catalogue__card { height: 260px; }
}

.koc-catalogue__card:hover .koc-catalogue__img {
  transform: scale(1.06);
}

.koc-catalogue__media {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.koc-catalogue__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}

.koc-catalogue__placeholder { width: 100%; height: 100%; }

.koc-catalogue__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.25) 55%, transparent 100%);
}

.koc-catalogue__content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  z-index: 1;
}

.koc-catalogue__title {
  font-size: 0.95rem;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 4px;
  line-height: 1.3;
}

.koc-catalogue__subtitle {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.78);
  margin-bottom: 10px;
}

.koc-catalogue__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 7px 16px;
  border-radius: 100px;
  font-size: 0.75rem;
  font-weight: 700;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 0.03em;
}

.koc-catalogue__btn--gold {
  background: #c9a050;
  color: #fff;
  border: 1.5px solid #c9a050;
}
.koc-catalogue__btn--gold:hover {
  background: #a87e30;
  border-color: #a87e30;
}

.koc-catalogue__btn--outline-white {
  background: transparent;
  color: #fff;
  border: 1.5px solid rgba(255,255,255,0.7);
}
.koc-catalogue__btn--outline-white:hover {
  background: rgba(255,255,255,0.15);
  border-color: #fff;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Catalogue grid",
  "disabled_on": { "groups": ["header", "footer"] },
  "max_blocks": 8,
  "blocks": [
    {
      "type": "catalogue",
      "name": "Catalogue",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Cover image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Affordable Cards" },
        { "type": "text", "id": "subtitle", "label": "Price range", "default": "MRP below ₹28" },
        { "type": "url", "id": "link", "label": "PDF / Page link" },
        { "type": "text", "id": "btn_label", "label": "Button label", "default": "Download PDF" },
        {
          "type": "select", "id": "btn_style", "label": "Button style",
          "options": [
            { "value": "gold", "label": "Gold" },
            { "value": "outline-white", "label": "Outline white" }
          ],
          "default": "gold"
        }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Download Our Catalogue" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Browse our full range by category and price" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-2" },
    {
      "type": "select", "id": "section_width", "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [
    {
      "name": "Catalogue grid",
      "category": "Products",
      "blocks": {
        "cat_1": { "type": "catalogue", "settings": { "title": "Affordable Cards", "subtitle": "MRP below ₹28", "btn_label": "Download PDF" } },
        "cat_2": { "type": "catalogue", "settings": { "title": "Mid-Range Cards", "subtitle": "₹29 to ₹206", "btn_label": "Download PDF" } },
        "cat_3": { "type": "catalogue", "settings": { "title": "Premium Cards", "subtitle": "₹48 to ₹2,250", "btn_label": "Download PDF" } },
        "cat_4": { "type": "catalogue", "settings": { "title": "Stock Clearance", "subtitle": "₹5 to ₹177", "btn_label": "Download PDF" } }
      },
      "block_order": ["cat_1","cat_2","cat_3","cat_4"]
    }
  ]
}
{% endschema %}
