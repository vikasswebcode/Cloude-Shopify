<section class="lifestyle-section">
  <div class="lifestyle-inner">

    <div class="lifestyle-img-wrap">

      <div class="lifestyle-img-frame">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              alt: section.settings.heading
          }}
        {% else %}
          {{ 'image' | placeholder_svg_tag }}
        {% endif %}
      </div>

      {% if section.settings.badge_text != blank %}
        <div class="ls-badge">
          {{ section.settings.badge_text }}
        </div>
      {% endif %}

    </div>

    <div class="lifestyle-content">

      {% if section.settings.kicker != blank %}
        <div class="ls-kicker">
          {{ section.settings.kicker }}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="ls-title">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="ls-copy">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <ul class="ls-features">
          {% for block in section.blocks %}
            <li {{ block.shopify_attributes }}>
              <div class="ls-dot"></div>

              <div>
                <strong>{{ block.settings.title }}</strong>

                {% if block.settings.text != blank %}
                  — {{ block.settings.text }}
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      <div class="ls-btns">

        {% if section.settings.btn_label_1 != blank %}
          <a href="{{ section.settings.btn_link_1 }}" class="ls-btn-p">
            {{ section.settings.btn_label_1 }}
          </a>
        {% endif %}

        {% if section.settings.btn_label_2 != blank %}
          <a href="{{ section.settings.btn_link_2 }}" class="ls-btn-s">
            {{ section.settings.btn_label_2 }}
          </a>
        {% endif %}

      </div>

    </div>

  </div>
</section>

{% style %}

.lifestyle-section{
  background: {{ section.settings.bg_color }};
  padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
}

.lifestyle-inner{
  max-width: 1300px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 70px;
}

.lifestyle-img-wrap{
  position: relative;
}

.lifestyle-img-frame{
  position: relative;
  overflow: hidden;
  border-radius: {{ section.settings.image_radius }}px;
}

.lifestyle-img-frame img,
.lifestyle-img-frame svg{
  width: 100%;
  height: auto;
  display: block;
}

.ls-badge{
  position: absolute;
  bottom: 25px;
  left: 25px;
  background: {{ section.settings.badge_bg }};
  color: {{ section.settings.badge_text_color }};
  padding: 12px 20px;
  border-radius: 100px;
  font-size: 14px;
  font-weight: 600;
  line-height: 1;
  box-shadow: 0 10px 30px rgba(0,0,0,.12);
}

.lifestyle-content{
  color: {{ section.settings.text_color }};
}

.ls-kicker{
  font-size: 14px;
  line-height: 1.2;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 18px;
  color: {{ section.settings.kicker_color }};
  font-weight: 600;
}

.ls-title{
  font-size: {{ section.settings.heading_size }}px;
  line-height: 1;
  margin: 0 0 25px;
  font-weight: 800;
  color: {{ section.settings.heading_color }};
  white-space: pre-line;
}

.ls-copy{
  font-size: 17px;
  line-height: 1.7;
  margin-bottom: 30px;
  color: {{ section.settings.copy_color }};
}

.ls-copy p{
  margin: 0;
}

.ls-features{
  list-style: none;
  padding: 0;
  margin: 0 0 35px;
}

.ls-features li{
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 18px;
  font-size: 16px;
  line-height: 1.5;
}

.ls-dot{
  width: 12px;
  height: 12px;
  background: {{ section.settings.dot_color }};
  border-radius: 50%;
  margin-top: 7px;
  flex-shrink: 0;
}

.ls-btns{
  display: flex;
  flex-wrap: wrap;
  gap: 15px;
}

.ls-btn-p,
.ls-btn-s{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 15px 28px;
  border-radius: 100px;
  text-decoration: none;
  font-weight: 600;
  transition: all .3s ease;
}

.ls-btn-p{
  background: {{ section.settings.primary_btn_bg }};
  color: {{ section.settings.primary_btn_text }};
}

.ls-btn-p:hover{
  opacity: .85;
}

.ls-btn-s{
  border: 1px solid {{ section.settings.secondary_btn_border }};
  color: {{ section.settings.secondary_btn_text }};
  background: transparent;
}

.ls-btn-s:hover{
  background: {{ section.settings.secondary_btn_border }};
  color: #ffffff;
}

@media screen and (max-width: 991px){

  .lifestyle-inner{
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .lifestyle-content{
    text-align: center;
  }

  .ls-features li{
    justify-content: center;
    text-align: left;
  }

  .ls-btns{
    justify-content: center;
  }

  .ls-title{
    font-size: 46px;
  }
}

@media screen and (max-width: 575px){

  .lifestyle-section{
    padding-left: 15px;
    padding-right: 15px;
  }

  .ls-title{
    font-size: 36px;
  }

  .ls-copy{
    font-size: 15px;
  }

  .ls-btn-p,
  .ls-btn-s{
    width: 100%;
  }

  .ls-badge{
    font-size: 12px;
    padding: 10px 16px;
  }
}

{% endstyle %}

{% schema %}
{
  "name": "Custom Lifestyle Sec",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Post-Workout ✓"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Top Small Heading",
      "default": "shake as part of your day"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "REFUEL.\nRECOVER.\nREPEAT."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our shakes are built for your actual life — post-gym, pre-work, mid-existential-crisis.</p>"
    },

    {
      "type": "text",
      "id": "btn_label_1",
      "label": "Primary Button Label",
      "default": "Shop shakes"
    },
    {
      "type": "url",
      "id": "btn_link_1",
      "label": "Primary Button Link"
    },

    {
      "type": "text",
      "id": "btn_label_2",
      "label": "Secondary Button Label",
      "default": "View recipes"
    },
    {
      "type": "url",
      "id": "btn_link_2",
      "label": "Secondary Button Link"
    },

    {
      "type": "header",
      "content": "Colors"
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f7f3ee"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "copy_color",
      "label": "Description Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "kicker_color",
      "label": "Kicker Color",
      "default": "#777777"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Feature Dot Color",
      "default": "#000000"
    },

    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#111111"
    },

    {
      "type": "header",
      "content": "Buttons"
    },

    {
      "type": "color",
      "id": "primary_btn_bg",
      "label": "Primary Button Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "primary_btn_text",
      "label": "Primary Button Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_btn_border",
      "label": "Secondary Button Border",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "secondary_btn_text",
      "label": "Secondary Button Text",
      "default": "#111111"
    },

    {
      "type": "header",
      "content": "Spacing"
    },

    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
