{% comment %}
  Horizontal Collection Showcase Section
  - Each block selects a different collection
  - Shows first product from each collection
  - Sale badge
  - Product image
  - Title
  - Compare price + sale price
  - Color swatches from variant option named "Color"
  - Size labels from variant option named "Size"
{% endcomment %}

<section class="horizontal-collection-showcase section-{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="hcs-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="hcs-grid">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}

        {% if collection != blank and collection.products.size > 0 %}
          {% assign product = collection.products.first %}

          <div class="hcs-card" {{ block.shopify_attributes }}>
            <a href="{{ product.url }}" class="hcs-card-link">

              {%- if product.compare_at_price > product.price -%}
                <span class="hcs-sale-badge">Sale</span>
              {%- endif -%}

              <div class="hcs-image-wrapper">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.title | escape }}"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                    loading="lazy"
                    class="hcs-image"
                  >
                {% endif %}
              </div>

              <div class="hcs-content">
                <h3 class="hcs-title">{{ product.title }}</h3>

                <div class="hcs-price">
                  {% if product.compare_at_price > product.price %}
                    <span class="hcs-compare-price">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                  <span class="hcs-current-price">
                    {{ product.price | money }}
                  </span>
                </div>

                {%- comment -%}
                  Color Swatches
                {%- endcomment -%}
                {% assign color_option_index = nil %}
                {% for option in product.options_with_values %}
                  {% if option.name == 'Color' or option.name == 'Colour' %}
                    {% assign color_option_index = forloop.index0 %}
                    {% break %}
                  {% endif %}
                {% endfor %}

                {% if color_option_index != nil %}
                  <div class="hcs-swatches">
                    {% assign shown_colors = '' %}
                    {% assign extra_count = 0 %}

                    {% for variant in product.variants %}
                      {% assign color_value = variant.options[color_option_index] %}

                      {% unless shown_colors contains color_value %}
                        {% assign shown_colors = shown_colors | append: color_value | append: ',' %}

                        {% if forloop.index <= 3 %}
                          <span
                            class="hcs-swatch"
                            title="{{ color_value }}"
                            style="background-color: {{ color_value | downcase }};"
                          ></span>
                        {% else %}
                          {% assign extra_count = extra_count | plus: 1 %}
                        {% endif %}
                      {% endunless %}
                    {% endfor %}

                    {% if extra_count > 0 %}
                      <span class="hcs-extra">+{{ extra_count }}</span>
                    {% endif %}
                  </div>
                {% endif %}

                {%- comment -%}
                  Size Variants
                {%- endcomment -%}
                {% assign size_option_index = nil %}
                {% for option in product.options_with_values %}
                  {% if option.name == 'Size' %}
                    {% assign size_option_index = forloop.index0 %}
                    {% break %}
                  {% endif %}
                {% endfor %}

                {% if size_option_index != nil %}
                  <div class="hcs-sizes">
                    {% assign shown_sizes = '' %}

                    {% for variant in product.variants %}
                      {% assign size_value = variant.options[size_option_index] %}

                      {% unless shown_sizes contains size_value %}
                        {% assign shown_sizes = shown_sizes | append: size_value | append: ',' %}
                        <span class="hcs-size">{{ size_value }}</span>
                      {% endunless %}
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
.section-{{ section.id }} {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: {{ section.settings.background }};
}

.hcs-heading {
  text-align: center;
  margin-bottom: 40px;
  font-size: 36px;
  font-weight: 700;
}

.hcs-grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: 24px;
}

.hcs-card {
  background: #f5f5f5;
  border-radius: 14px;
  overflow: hidden;
  position: relative;
  transition: all 0.3s ease;
}

.hcs-card:hover {
  transform: translateY(-5px);
}

.hcs-card-link {
  display: block;
  text-decoration: none;
  color: inherit;
}

.hcs-sale-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  background: #ff5a3c;
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 4px;
  z-index: 2;
}

.hcs-image-wrapper {
  background: #ececec;
  aspect-ratio: 4 / 5;
  overflow: hidden;
}

.hcs-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.hcs-content {
  padding: 20px;
  text-align: center;
}

.hcs-title {
  font-size: 24px;
  font-weight: 700;
  margin: 0 0 12px;
  line-height: 1.3;
}

.hcs-price {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}

.hcs-compare-price {
  color: #777;
  text-decoration: line-through;
  font-size: 20px;
  font-weight: 600;
}

.hcs-current-price {
  color: #111;
  font-size: 24px;
  font-weight: 700;
}

.hcs-swatches {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.hcs-swatch {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 1px solid #999;
  display: inline-block;
}

.hcs-extra {
  font-size: 18px;
  font-weight: 500;
  color: #333;
}

.hcs-sizes {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8px;
}

.hcs-size {
  font-size: 13px;
  font-weight: 600;
  border: 1px solid #ddd;
  padding: 4px 8px;
  border-radius: 4px;
  background: #fff;
}

@media screen and (max-width: 991px) {
  .hcs-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .hcs-title {
    font-size: 20px;
  }

  .hcs-current-price,
  .hcs-compare-price {
    font-size: 18px;
  }
}

@media screen and (max-width: 767px) {
  .hcs-grid {
    grid-template-columns: 1fr;
  }

  .hcs-heading {
    font-size: 28px;
  }
}
</style>

{% schema %}
{
  "name": "Custom Collection Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Column",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Collection Grid",
      "category": "Custom",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}