
<section class="horizontal-collection-showcase section-{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="hcs-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="hcs-grid">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}

        {% if collection != blank and collection.products.size > 0 %}
          {% assign product = collection.products.first %}
          {% assign current_variant = product.selected_or_first_available_variant %}

          <div class="hcs-card" {{ block.shopify_attributes }}>
            <div
              class="hcs-card-inner"
              data-product-id="{{ product.id }}"
              data-product-url="{{ product.url }}"
            >

              <script type="application/json" class="hcs-variants-json">
                {{ product.variants | json }}
              </script>

              {%- if product.compare_at_price > product.price -%}
                <span class="hcs-sale-badge">Sale</span>
              {%- endif -%}

              <a href="{{ product.url }}" class="hcs-image-link">
                <div class="hcs-image-wrapper">
                  {% if current_variant.featured_image %}
                    {% assign display_image = current_variant.featured_image %}
                  {% else %}
                    {% assign display_image = product.featured_image %}
                  {% endif %}

                  {% if display_image %}
                    <img
                      src="{{ display_image | image_url: width: 800 }}"
                      alt="{{ product.title | escape }}"
                      width="{{ display_image.width }}"
                      height="{{ display_image.height }}"
                      loading="lazy"
                      class="hcs-image"
                    >
                  {% endif %}
                </div>
              </a>

              <div class="hcs-content">
                <h3 class="hcs-title">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>

                <div class="hcs-price">
                  {% if current_variant.compare_at_price > current_variant.price %}
                    <span class="hcs-compare-price">
                      {{ current_variant.compare_at_price | money }}
                    </span>
                  {% endif %}
                  <span class="hcs-current-price">
                    {{ current_variant.price | money }}
                  </span>
                </div>

                {% assign color_option_index = nil %}
                {% for option in product.options_with_values %}
                  {% assign option_name = option.name | downcase %}
                  {% if option_name == 'color' or option_name == 'colour' %}
                    {% assign color_option_index = forloop.index0 %}
                    {% break %}
                  {% endif %}
                {% endfor %}

                {% if color_option_index != nil %}
                  <div class="hcs-swatches" data-option-index="{{ color_option_index }}">
                    {% assign shown_colors = '' %}
                    {% assign visible_count = 0 %}
                    {% assign extra_count = 0 %}

                    {% for variant in product.variants %}
                      {% assign color_value = variant.options[color_option_index] %}
                      {% assign token = '|' | append: color_value | append: '|' %}

                      {% unless shown_colors contains token %}
                        {% assign shown_colors = shown_colors | append: token %}

                        {% if visible_count < 3 %}
                          <button
                            type="button"
                            class="hcs-swatch{% if visible_count == 0 %} active{% endif %}"
                            data-value="{{ color_value | escape }}"
                            data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 800 }}{% endif %}"
                            title="{{ color_value }}"
                            style="background-color: {{ color_value | downcase }};"
                          ></button>
                          {% assign visible_count = visible_count | plus: 1 %}
                        {% else %}
                          {% assign extra_count = extra_count | plus: 1 %}
                        {% endif %}
                      {% endunless %}
                    {% endfor %}

                    {% if extra_count > 0 %}
                      <span class="hcs-extra">+{{ extra_count }}</span>
                    {% endif %}
                  </div>
                {% endif %}

                {% assign size_option_index = nil %}
                {% for option in product.options_with_values %}
                  {% assign option_name = option.name | downcase %}
                  {% if option_name == 'size' %}
                    {% assign size_option_index = forloop.index0 %}
                    {% break %}
                  {% endif %}
                {% endfor %}

                {% if size_option_index != nil %}
                  <div class="hcs-sizes" data-option-index="{{ size_option_index }}">
                    {% assign shown_sizes = '' %}

                    {% for variant in product.variants %}
                      {% assign size_value = variant.options[size_option_index] %}
                      {% assign token = '|' | append: size_value | append: '|' %}

                      {% unless shown_sizes contains token %}
                        {% assign shown_sizes = shown_sizes | append: token %}
                        <button
                          type="button"
                          class="hcs-size{% if forloop.first %} active{% endif %}"
                          data-value="{{ size_value | escape }}"
                        >
                          {{ size_value }}
                        </button>
                      {% endunless %}
                    {% endfor %}
                  </div>
                {% endif %}

                <input
                  type="hidden"
                  class="hcs-variant-id"
                  value="{{ current_variant.id }}"
                >

                <button
                  type="button"
                  class="hcs-add-to-cart"
                  {% unless current_variant.available %}disabled{% endunless %}
                >
                  {% if current_variant.available %}
                    Add to Cart
                  {% else %}
                    Sold Out
                  {% endif %}
                </button>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
.section-{{ section.id }} {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: {{ section.settings.background }};
}

.hcs-heading {
  text-align: center;
  margin-bottom: 40px;
  font-size: 36px;
  font-weight: 700;
}

.hcs-grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: 24px;
}

.hcs-card {
  background: #f5f5f5;
  border-radius: 14px;
  overflow: hidden;
  position: relative;
  transition: all 0.3s ease;
}

.hcs-card:hover {
  transform: translateY(-5px);
}

.hcs-sale-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  background: #ff5a3c;
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 4px;
  z-index: 2;
}

.hcs-image-link,
.hcs-title a {
  text-decoration: none;
  color: inherit;
}

.hcs-image-wrapper {
  background: #ececec;
  aspect-ratio: 4 / 5;
  overflow: hidden;
}

.hcs-image {
  width: 100%; height: 100%; object-fit: cover; display: block;
}

.hcs-content {
  padding: 20px;
  text-align: center;
}

.hcs-title {
  font-size: 24px;
  font-weight: 700;
  margin: 0 0 12px;
  line-height: 1.3;
}

.hcs-price {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}

.hcs-compare-price {
  color: #777;
  text-decoration: line-through;
  font-size: 20px;
  font-weight: 600;
}

.hcs-current-price {
  color: #111;
  font-size: 24px;
  font-weight: 700;
}

.hcs-swatches,
.hcs-sizes {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.hcs-swatches {
  margin-bottom: 12px;
}

.hcs-sizes {
  margin-bottom: 16px;
}

.hcs-swatch {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 1px solid #999;
  cursor: pointer;
  padding: 0;
}

.hcs-swatch.active {
  border: 2px solid #111;
  transform: scale(1.1);
}

.hcs-size {
  font-size: 13px;
  font-weight: 600;
  border: 1px solid #ddd;
  padding: 4px 8px;
  border-radius: 4px;
  background: #fff;
  cursor: pointer;
}

.hcs-size.active {
  background: #111;
  color: #fff;
  border-color: #111;
}

.hcs-extra {
  font-size: 18px;
  font-weight: 500;
  color: #333;
}

.hcs-add-to-cart {
  width: 100%;
  padding: 12px 20px;
  border: none;
  border-radius: 8px;
  background: #111;
  color: #fff;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s;
}

.hcs-add-to-cart:hover {
  background: #333;
}

.hcs-add-to-cart:disabled {
  background: #999;
  cursor: not-allowed;
}

@media screen and (max-width: 991px) {
  .hcs-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .hcs-title {
    font-size: 20px;
  }

  .hcs-current-price,
  .hcs-compare-price {
    font-size: 18px;
  }
}

@media screen and (max-width: 767px) {
  .hcs-grid {
    grid-template-columns: 1fr;
  }

  .hcs-heading {
    font-size: 28px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const currencySymbol = "{{ 0 | money | replace: '0.00', '' | replace: '0,00', '' | strip }}";

  function formatMoney(cents) {
    return `${currencySymbol}${(cents / 100).toFixed(2)}`;
  }

  function updateCardVariant(card) {
    const variantsJson = card.querySelector('.hcs-variants-json');
    if (!variantsJson) return;

    const variants = JSON.parse(variantsJson.textContent);

    const swatchContainer = card.querySelector('.hcs-swatches');
    const sizeContainer = card.querySelector('.hcs-sizes');

    let selectedColor = null;
    let selectedSize = null;

    // Selected Color
    if (swatchContainer) {
      const activeSwatch = swatchContainer.querySelector('.hcs-swatch.active');
      if (activeSwatch) {
        selectedColor = activeSwatch.dataset.value;
      }
    }

    // Selected Size
    if (sizeContainer) {
      const activeSize = sizeContainer.querySelector('.hcs-size.active');
      if (activeSize) {
        selectedSize = activeSize.dataset.value;
      }
    }

    // Find exact matching variant
    const matchedVariant = variants.find((variant) => {
      let colorMatch = true;
      let sizeMatch = true;

      if (selectedColor) {
        colorMatch = variant.options.some(
          (option) =>
            option &&
            option.toString().toLowerCase() === selectedColor.toLowerCase()
        );
      }

      if (selectedSize) {
        sizeMatch = variant.options.some(
          (option) =>
            option &&
            option.toString().toLowerCase() === selectedSize.toLowerCase()
        );
      }

      return colorMatch && sizeMatch;
    });

    const atcButton = card.querySelector('.hcs-add-to-cart');
    const inputHidden = card.querySelector('.hcs-variant-id');
    const currentPriceEl = card.querySelector('.hcs-current-price');
    const priceWrapper = card.querySelector('.hcs-price');
    let comparePriceEl = card.querySelector('.hcs-compare-price');
    const imgEl = card.querySelector('.hcs-image');

    if (!matchedVariant) {
      if (atcButton) {
        atcButton.disabled = true;
        atcButton.textContent = 'Unavailable';
      }
      return;
    }

    // Update hidden variant ID
    if (inputHidden) {
      inputHidden.value = matchedVariant.id;
    }

    // Update product URLs
    const productUrl = card.dataset.productUrl;
    if (productUrl) {
      card.querySelectorAll('.hcs-image-link, .hcs-title a').forEach((link) => {
        link.href = `${productUrl}?variant=${matchedVariant.id}`;
      });
    }

    // Update image
    if (imgEl && matchedVariant.featured_image) {
      const imageUrl =
        matchedVariant.featured_image.src ||
        matchedVariant.featured_image.url;

      if (imageUrl) {
        imgEl.src = imageUrl;
        imgEl.removeAttribute('srcset');
      }
    }

    // Update price
    if (currentPriceEl) {
      currentPriceEl.textContent = formatMoney(matchedVariant.price);
    }

    // Update compare at price
    if (
      matchedVariant.compare_at_price &&
      matchedVariant.compare_at_price > matchedVariant.price
    ) {
      if (!comparePriceEl && priceWrapper) {
        comparePriceEl = document.createElement('span');
        comparePriceEl.className = 'hcs-compare-price';
        priceWrapper.insertBefore(comparePriceEl, currentPriceEl);
      }

      if (comparePriceEl) {
        comparePriceEl.textContent = formatMoney(
          matchedVariant.compare_at_price
        );
      }
    } else if (comparePriceEl) {
      comparePriceEl.remove();
    }

    // Update button state
    if (atcButton) {
      if (matchedVariant.available) {
        atcButton.disabled = false;
        atcButton.textContent = 'Add to Cart';
      } else {
        atcButton.disabled = true;
        atcButton.textContent = 'Sold Out';
      }
    }
  }

  // Handle clicks for all cards (works even with multiple cards on one page)
  document.addEventListener('click', function (e) {
    const swatch = e.target.closest('.hcs-swatch');
    const sizeBtn = e.target.closest('.hcs-size');
    const atcButton = e.target.closest('.hcs-add-to-cart');

    // Swatch Click
    if (swatch) {
      e.preventDefault();

      const card = swatch.closest('.hcs-card-inner');
      if (!card) return;

      // Remove active only within current card
      card.querySelectorAll('.hcs-swatch').forEach((btn) => {
        btn.classList.remove('active');
      });

      swatch.classList.add('active');

      updateCardVariant(card);
      return;
    }

    // Size Click
    if (sizeBtn) {
      e.preventDefault();

      const card = sizeBtn.closest('.hcs-card-inner');
      if (!card) return;

      // Remove active only within current card
      card.querySelectorAll('.hcs-size').forEach((btn) => {
        btn.classList.remove('active');
      });

      sizeBtn.classList.add('active');

      updateCardVariant(card);
      return;
    }

    // Add to Cart Click
    if (atcButton) {
      e.preventDefault();

      const card = atcButton.closest('.hcs-card-inner');
      if (!card) return;

      const variantInput = card.querySelector('.hcs-variant-id');
      if (!variantInput || !variantInput.value) return;

      const variantId = variantInput.value;

      atcButton.disabled = true;
      atcButton.textContent = 'Adding...';

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          id: variantId,
          quantity: 1
        })
      })
        .then((response) => {
          if (!response.ok) {
            throw new Error('Failed to add to cart');
          }
          return response.json();
        })
        .then(() => {
          atcButton.textContent = 'Added!';

          // Refresh cart drawer if available
          if (
            document.querySelector('cart-drawer') ||
            document.querySelector('cart-notification')
          ) {
            window.dispatchEvent(new Event('cart:updated'));
          }

          setTimeout(() => {
            atcButton.textContent = 'Add to Cart';
            atcButton.disabled = false;
          }, 2000);
        })
        .catch((error) => {
          console.error(error);
          atcButton.textContent = 'Error';

          setTimeout(() => {
            atcButton.textContent = 'Add to Cart';
            atcButton.disabled = false;
          }, 2000);
        });
    }
  });

  // Initialize all cards on page
  document.querySelectorAll('.hcs-card-inner').forEach((card) => {
    updateCardVariant(card);
  });
});
</script>


{% schema %}
{
  "name": "Custom Collection Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Column",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Collection Grid",
      "category": "Custom",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}


