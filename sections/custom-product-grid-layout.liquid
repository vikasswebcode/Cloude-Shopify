
<section class="horizontal-collection-showcase section-{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="hcs-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="hcs-grid">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}

        {% if collection != blank and collection.products.size > 0 %}
          {% assign product = collection.products.first %}
          {% assign current_variant = product.selected_or_first_available_variant %}

          <div class="hcs-card" {{ block.shopify_attributes }}>
            <div
              class="hcs-card-inner"
              data-product-id="{{ product.id }}"
              data-product-url="{{ product.url }}"
            >

              <script type="application/json" class="hcs-variants-json">
                {{ product.variants | json }}
              </script>

              {%- if product.compare_at_price > product.price -%}
                <span class="hcs-sale-badge">Sale</span>
              {%- endif -%}

              <a href="{{ product.url }}" class="hcs-image-link">
                <div class="hcs-image-wrapper">
                  {% if current_variant.featured_image %}
                    {% assign display_image = current_variant.featured_image %}
                  {% else %}
                    {% assign display_image = product.featured_image %}
                  {% endif %}

                  {% if display_image %}
                    <img
                      src="{{ display_image | image_url: width: 800 }}"
                      alt="{{ product.title | escape }}"
                      width="{{ display_image.width }}"
                      height="{{ display_image.height }}"
                      loading="lazy"
                      class="hcs-image"
                    >
                  {% endif %}
                </div>
              </a>

              <div class="hcs-content">
                <h3 class="hcs-title">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>

                <div class="hcs-price">
                  {% if current_variant.compare_at_price > current_variant.price %}
                    <span class="hcs-compare-price">
                      {{ current_variant.compare_at_price | money }}
                    </span>
                  {% endif %}
                  <span class="hcs-current-price">
                    {{ current_variant.price | money }}
                  </span>
                </div>

                {% assign color_option_index = nil %}
                {% for option in product.options_with_values %}
                  {% assign option_name = option.name | downcase %}
                  {% if option_name == 'color' or option_name == 'colour' %}
                    {% assign color_option_index = forloop.index0 %}
                    {% break %}
                  {% endif %}
                {% endfor %}

                {% if color_option_index != nil %}
                  <div class="hcs-swatches" data-option-index="{{ color_option_index }}">
                    {% assign shown_colors = '' %}
                    {% assign visible_count = 0 %}
                    {% assign extra_count = 0 %}

                    {% for variant in product.variants %}
                      {% assign color_value = variant.options[color_option_index] %}
                      {% assign token = '|' | append: color_value | append: '|' %}

                      {% unless shown_colors contains token %}
                        {% assign shown_colors = shown_colors | append: token %}

                        {% if visible_count < 3 %}
                          <button
                            type="button"
                            class="hcs-swatch{% if visible_count == 0 %} active{% endif %}"
                            data-value="{{ color_value | escape }}"
                            data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 800 }}{% endif %}"
                            title="{{ color_value }}"
                            style="background-color: {{ color_value | downcase }};"
                          ></button>
                          {% assign visible_count = visible_count | plus: 1 %}
                        {% else %}
                          {% assign extra_count = extra_count | plus: 1 %}
                        {% endif %}
                      {% endunless %}
                    {% endfor %}

                    {% if extra_count > 0 %}
                      <span class="hcs-extra">+{{ extra_count }}</span>
                    {% endif %}
                  </div>
                {% endif %}

                {% assign size_option_index = nil %}
                {% for option in product.options_with_values %}
                  {% assign option_name = option.name | downcase %}
                  {% if option_name == 'size' %}
                    {% assign size_option_index = forloop.index0 %}
                    {% break %}
                  {% endif %}
                {% endfor %}

                {% if size_option_index != nil %}
                  <div class="hcs-sizes" data-option-index="{{ size_option_index }}">
                    {% assign shown_sizes = '' %}

                    {% for variant in product.variants %}
                      {% assign size_value = variant.options[size_option_index] %}
                      {% assign token = '|' | append: size_value | append: '|' %}

                      {% unless shown_sizes contains token %}
                        {% assign shown_sizes = shown_sizes | append: token %}
                        <button
                          type="button"
                          class="hcs-size{% if forloop.first %} active{% endif %}"
                          data-value="{{ size_value | escape }}"
                        >
                          {{ size_value }}
                        </button>
                      {% endunless %}
                    {% endfor %}
                  </div>
                {% endif %}

                <input
                  type="hidden"
                  class="hcs-variant-id"
                  value="{{ current_variant.id }}"
                >

                <a href="{{ product.url }}?variant={{ current_variant.id }}"
                class="hcs-add-to-cart hcs-submit-button{% unless current_variant.available %} disabled{% endunless %}"
                {% unless current_variant.available %}aria-disabled="true"{% endunless %}
                >
                {% if current_variant.available %}
                    Submit
                {% else %}
                    Sold Out
                {% endif %}
                </a>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
.section-{{ section.id }} {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: {{ section.settings.background }};
}

.hcs-heading {
  text-align: center;
  margin-bottom: 40px;
  font-size: 36px;
  font-weight: 700;
}

.hcs-grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: 24px;
}

.hcs-card {
  background: #f5f5f5;
  border-radius: 14px;
  overflow: hidden;
  position: relative;
  transition: all 0.3s ease;
}

.hcs-card:hover {
  transform: translateY(-5px);
}

.hcs-sale-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  background: #ff5a3c;
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 4px;
  z-index: 2;
}

.hcs-image-link,
.hcs-title a {
  text-decoration: none;
  color: inherit;
}

.hcs-image-wrapper {
  background: #ececec;
  aspect-ratio: 4 / 5;
  overflow: hidden;
}

.hcs-image {
  width: 100%; height: 100%; object-fit: cover; display: block;
}

.hcs-content {
  padding: 20px;
  text-align: center;
}

.hcs-title {
  font-size: 24px;
  font-weight: 700;
  margin: 0 0 12px;
  line-height: 1.3;
}

.hcs-price {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}

.hcs-compare-price {
  color: #777;
  text-decoration: line-through;
  font-size: 20px;
  font-weight: 600;
}

.hcs-current-price {
  color: #111;
  font-size: 24px;
  font-weight: 700;
}

.hcs-swatches,
.hcs-sizes {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.hcs-swatches {
  margin-bottom: 12px;
}

.hcs-sizes {
  margin-bottom: 16px;
}

.hcs-swatch {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 1px solid #999;
  cursor: pointer;
  padding: 0;
}

.hcs-swatch.active {
  border: 2px solid #111;
  transform: scale(1.1);
}

.hcs-size {
  font-size: 13px;
  font-weight: 600;
  border: 1px solid #ddd;
  padding: 4px 8px;
  border-radius: 4px;
  background: #fff;
  cursor: pointer;
}

.hcs-size.active {
  background: #111;
  color: #fff;
  border-color: #111;
}

.hcs-extra {
  font-size: 18px;
  font-weight: 500;
  color: #333;
}

.hcs-add-to-cart {
  width: 100%;
  padding: 12px 20px;
  border: none;
  border-radius: 8px;
  background: #111;
  color: #fff;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s;
}

.hcs-add-to-cart:hover {
  background: #333;
}

.hcs-add-to-cart:disabled {
  background: #999;
  cursor: not-allowed;
}

@media screen and (max-width: 991px) {
  .hcs-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .hcs-title {
    font-size: 20px;
  }

  .hcs-current-price,
  .hcs-compare-price {
    font-size: 18px;
  }
}

@media screen and (max-width: 767px) {
  .hcs-grid {
    grid-template-columns: 1fr;
  }

  .hcs-heading {
    font-size: 28px;
  }
}
</style>

/* Replace your entire <script>...</script> block with this improved version */

<script>
document.addEventListener('DOMContentLoaded', function () {
  /**
   * Format money safely
   */
  function formatMoney(cents) {
    if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
      return Shopify.formatMoney(cents, "{{ shop.money_format }}");
    }
    return (cents / 100).toFixed(2);
  }

  /**
   * Get selected option values from active buttons
   */
  function getSelectedOptions(card) {
    const selected = {};

    const activeSwatch = card.querySelector('.hcs-swatches .hcs-swatch.active');
    if (activeSwatch) {
      selected.color = activeSwatch.dataset.value;
    }

    const activeSize = card.querySelector('.hcs-sizes .hcs-size.active');
    if (activeSize) {
      selected.size = activeSize.dataset.value;
    }

    return selected;
  }

  /**
   * Find matching variant based on exact option positions
   */
  function findMatchingVariant(card, variants) {
    const swatchContainer = card.querySelector('.hcs-swatches');
    const sizeContainer = card.querySelector('.hcs-sizes');

    const selected = getSelectedOptions(card);

    const colorOptionIndex = swatchContainer
      ? parseInt(swatchContainer.dataset.optionIndex, 10)
      : null;

    const sizeOptionIndex = sizeContainer
      ? parseInt(sizeContainer.dataset.optionIndex, 10)
      : null;

    // First try exact match
    let matchedVariant = variants.find(function (variant) {
      let matches = true;

      if (
        colorOptionIndex !== null &&
        selected.color &&
        variant.options[colorOptionIndex] !== selected.color
      ) {
        matches = false;
      }

      if (
        sizeOptionIndex !== null &&
        selected.size &&
        variant.options[sizeOptionIndex] !== selected.size
      ) {
        matches = false;
      }

      return matches;
    });

    // Fallback to first available variant
    if (!matchedVariant) {
      matchedVariant =
        variants.find(function (variant) {
          return variant.available;
        }) || variants[0];
    }

    return matchedVariant;
  }

  /**
   * Update card UI according to selected variant
   */
  function updateCardVariant(card) {
    const variantsJson = card.querySelector('.hcs-variants-json');
    if (!variantsJson) return;

    let variants = [];
    try {
      variants = JSON.parse(variantsJson.textContent);
    } catch (e) {
      console.error('Invalid variant JSON', e);
      return;
    }

    if (!variants.length) return;

    const matchedVariant = findMatchingVariant(card, variants);
    if (!matchedVariant) return;

    const productUrl = card.dataset.productUrl;

    const submitButton = card.querySelector('.hcs-submit-button');
    const hiddenInput = card.querySelector('.hcs-variant-id');
    const image = card.querySelector('.hcs-image');
    const currentPrice = card.querySelector('.hcs-current-price');
    const priceWrapper = card.querySelector('.hcs-price');
    let comparePrice = card.querySelector('.hcs-compare-price');

    /* Update hidden variant input */
    if (hiddenInput) {
      hiddenInput.value = matchedVariant.id;
    }

    /* Update all links with selected variant */
    if (productUrl) {
      const variantUrl = productUrl + '?variant=' + matchedVariant.id;

      card.querySelectorAll('.hcs-image-link, .hcs-title a, .hcs-submit-button')
        .forEach(function (link) {
          if (link.tagName.toLowerCase() === 'a') {
            link.href = variantUrl;
          }
        });
    }

    /* Update image */
    if (
      image &&
      matchedVariant.featured_image &&
      (matchedVariant.featured_image.src || matchedVariant.featured_image.url)
    ) {
      const imageUrl =
        matchedVariant.featured_image.src ||
        matchedVariant.featured_image.url;

      if (image.src !== imageUrl) {
        image.src = imageUrl;
        image.removeAttribute('srcset');
      }
    }

    /* Update current price */
    if (currentPrice) {
      currentPrice.textContent = formatMoney(matchedVariant.price);
    }

    /* Update compare-at price */
    if (
      matchedVariant.compare_at_price &&
      matchedVariant.compare_at_price > matchedVariant.price
    ) {
      if (!comparePrice && priceWrapper) {
        comparePrice = document.createElement('span');
        comparePrice.className = 'hcs-compare-price';
        priceWrapper.insertBefore(comparePrice, currentPrice);
      }

      if (comparePrice) {
        comparePrice.textContent = formatMoney(
          matchedVariant.compare_at_price
        );
      }
    } else if (comparePrice) {
      comparePrice.remove();
    }

    /* Update button state */
    if (submitButton) {
      if (matchedVariant.available) {
        submitButton.classList.remove('disabled');
        submitButton.removeAttribute('aria-disabled');
        submitButton.textContent = 'Submit';
      } else {
        submitButton.classList.add('disabled');
        submitButton.setAttribute('aria-disabled', 'true');
        submitButton.textContent = 'Sold Out';
      }
    }
  }

  /**
   * Activate one button in a group
   */
  function setActiveButton(button, selector) {
    const container = button.parentElement;
    if (!container) return;

    container.querySelectorAll(selector).forEach(function (btn) {
      btn.classList.remove('active');
    });

    button.classList.add('active');
  }

  /**
   * Event delegation
   */
  document.addEventListener('click', function (event) {
    /* Color swatch click */
    const swatch = event.target.closest('.hcs-swatch');
    if (swatch) {
      event.preventDefault();

      const card = swatch.closest('.hcs-card-inner');
      if (!card) return;

      setActiveButton(swatch, '.hcs-swatch');
      updateCardVariant(card);
      return;
    }

    /* Size click */
    const sizeButton = event.target.closest('.hcs-size');
    if (sizeButton) {
      event.preventDefault();

      const card = sizeButton.closest('.hcs-card-inner');
      if (!card) return;

      setActiveButton(sizeButton, '.hcs-size');
      updateCardVariant(card);
      return;
    }

    /* Prevent disabled button clicks */
    const disabledButton = event.target.closest('.hcs-submit-button.disabled');
    if (disabledButton) {
      event.preventDefault();
    }
  });

  /**
   * Initialize all product cards
   */
  document.querySelectorAll('.hcs-card-inner').forEach(function (card) {
    updateCardVariant(card);
  });
});
</script>


{% schema %}
{
  "name": "Custom Collection Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Column",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Collection Grid",
      "category": "Custom",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}


