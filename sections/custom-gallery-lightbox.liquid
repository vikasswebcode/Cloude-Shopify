<!-- ===========Gallery with popups========= -->
 <div class="lx-gallery-sec">
  <div class="page-width">
    <div class="lx-gallery-hed">
        <h2> {{ section.settings.hed }} </h2>
    </div>
    <div class="lx-gallery" data-columns="{{ section.settings.columns }}">
      {% for block in section.blocks %}
        {% if block.settings.img %}
        <div class="lx-item" data-index="{{ forloop.index0 }}">
          <img src="{{ block.settings.img | image_url: width: 900 }}">
        </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
<div class="lx-popup">
  <div class="lx-overlay"> &nbsp; </div>
  <div class="lx-inner">
    <div class="lx-top">
      <div class="lx-count"><span id="lx-current">1</span> / {{ section.blocks.size }}</div>
      <button class="lx-close">×</button>
    </div>
    <div class="lx-slider">
      {% for block in section.blocks %}
      <div class="lx-slide">
        <img src="{{ block.settings.img | image_url: width: 1600 }}" width="" height="">
      </div>
      {% endfor %}
    </div>
    <button class="lx-prev">‹</button>
    <button class="lx-next">›</button>
    <div class="lx-thumbs">
      {% for block in section.blocks %}
      <div class="lx-thumb" data-index="{{ forloop.index0 }}">
        <img src="{{ block.settings.img | image_url: width: 200 }}" width="" height="">
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
.lx-gallery-sec{
  padding:60px 0;
} 
.lx-gallery-sec .page-width{
  max-width:100%;
}
.lx-item{
  opacity:0;
  transform:translateY(40px);
  animation:fadeUp .8s ease forwards;
}
.lx-item:nth-child(2){animation-delay:.1s}
.lx-item:nth-child(3){animation-delay:.2s}
.lx-item:nth-child(4){animation-delay:.3s}
.lx-item:nth-child(5){animation-delay:.4s}
@keyframes fadeUp{
  to{opacity:1;transform:translateY(0)}
}
.lx-gallery{
  display:grid;
  gap:14px;
  grid-template-columns:repeat(4,1fr);
}
.lx-gallery[data-columns="3"]{grid-template-columns:repeat(3,1fr)}

.lx-item{
  cursor:pointer;
  border-radius:14px;
  overflow:hidden;
  position:relative;
}
.lx-item img{
  width:100%;
  transition:.8s cubic-bezier(.22,1,.36,1);
  display:block; 
  aspect-ratio: 0.9;
  object-fit: cover;
}
.lx-item:hover img{
  transform:scale(1.12);
}
.lx-item:after{
  background: rgba(255, 255, 255, 0.3);
  bottom: 0;
  content: "";
  left: 50%;
  position: absolute;
  right: 51%;
  top: 0;
  opacity: 1;
  pointer-events: none;
  -webkit-transition: all 500ms linear;
  transition: all 500ms linear;
}
.lx-item:hover:after{
  left: 0;
  right: 0;
  opacity: 0;
  -webkit-transition: all 500ms linear;
  transition: all 500ms linear;
}
@keyframes shine{
  to{transform:translateX(100%)}
}
.lx-popup{position:fixed;inset:0;display:none;z-index:9999}
.lx-popup.active{display:block}
.lx-overlay{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.92);
  backdrop-filter: blur(8px);
  opacity:0;
  animation:fadeOverlay .4s forwards;
}
@keyframes fadeOverlay{to{opacity:1}}
.lx-inner{
  position:absolute;
  top:50%;left:50%;
  transform:translate(-50%,-50%) scale(.85);
  width:92%;
  max-width:1100px;
  opacity:0;
  animation:zoomIn .45s cubic-bezier(.22,1,.36,1) forwards;
}
@keyframes zoomIn{
  to{transform:translate(-50%,-50%) scale(1);opacity:1}
}
.lx-top{
  position:absolute;
  top:-45px;
  width:100%;
  display:flex;
  justify-content:space-between;
  color:#fff;
}
.lx-close{
  background:#ffffff22;
  border:0;
  color:#fff;
  width:36px;height:36px;
  border-radius:6px;
  cursor:pointer;
  transition:.3s;
}
.lx-close:hover{
  background:#fff;
  color:#000;
  transform:rotate(90deg);
}
.lx-slider{position:relative;height:65vh;overflow:hidden}
.lx-slide{
  position:absolute;
  inset:0;
  opacity:0;
  transform:scale(.75);
  transition:.7s cubic-bezier(.22,1,.36,1);
}
.lx-slide.active{
  opacity:1;
  transform:scale(1);
  z-index:3;
}
.lx-slide.prev{transform:translateX(-60%) scale(.85);opacity:.2}
.lx-slide.next{transform:translateX(60%) scale(.85);opacity:.2}
.lx-slide img{
  width:100%;
  height:100%;
  object-fit:contain;
  border-radius:14px;
  box-shadow:0 25px 70px rgba(0,0,0,.6);
}
.lx-prev,.lx-next{
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  width:48px;height:48px;
  border-radius:50%;
  background:#ffffff22;
  color:#fff;
  border:0;
  font-size:28px;
  cursor:pointer;
  transition:.3s;
}
.lx-prev{left:-65px}
.lx-next{right:-65px}

.lx-prev:hover,.lx-next:hover{
  transform:translateY(-50%) scale(1.15);
  background:#fff;
  color:#000;
}
.lx-thumbs{
  display:flex;
  gap:10px;
  margin-top:18px;
  justify-content:center;
}
.lx-thumb{
  width:70px;height:70px;
  border-radius:8px;
  overflow:hidden;
  opacity:.5;
  cursor:pointer;
  transition:.35s;
}
.lx-thumb:hover{
  transform:scale(1.1);
  opacity:1;
}
.lx-thumb.active{
  border:2px solid #fff;
  opacity:1;
}
body.lx-lock{overflow:hidden}
.lx-thumb img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
}
.lx-gallery-sec h2 {
    margin: 0 0 30px;
    text-align: center;
    text-transform: uppercase;
    font-style: italic;
    font-size: 48px;
    font-weight: 900;
}
@media(max-width:1199px){
  .lx-gallery-sec h2 {
      font-size: 36px;
  }
}
@media(max-width:991px){
  .lx-gallery-sec h2 {
      font-size: 30px;
  }
}
@media(max-width:767px){
  .lx-gallery{grid-template-columns:repeat(2,1fr)!important}
  .lx-prev{left:10px}
  .lx-next{right:10px}
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function(){

  const items = document.querySelectorAll(".lx-item");
  const popup = document.querySelector(".lx-popup");
  const slides = document.querySelectorAll(".lx-slide");
  const thumbs = document.querySelectorAll(".lx-thumb");
  const prev = document.querySelector(".lx-prev");
  const next = document.querySelector(".lx-next");
  const closeBtn = document.querySelector(".lx-close");
  const overlay = document.querySelector(".lx-overlay");
  const currentEl = document.getElementById("lx-current");

  let current = 0;

  function updateSlider(i){
    slides.forEach((s,idx)=>{
      s.classList.remove("active","prev","next");

      if(idx===i){s.classList.add("active")}
      else if(idx === (i-1+slides.length)%slides.length){s.classList.add("prev")}
      else if(idx === (i+1)%slides.length){s.classList.add("next")}
    });

    thumbs.forEach(t=>t.classList.remove("active"));
    if(thumbs[i]) thumbs[i].classList.add("active");

    currentEl.textContent = i+1;
  }

  items.forEach(item=>{
    item.onclick=()=>{
      current = parseInt(item.dataset.index);
      popup.classList.add("active");
      document.body.classList.add("lx-lock");
      updateSlider(current);
    }
  });

  next.onclick=()=>{
    current = (current+1)%slides.length;
    updateSlider(current);
  }

  prev.onclick=()=>{
    current = (current-1+slides.length)%slides.length;
    updateSlider(current);
  }

  thumbs.forEach(t=>{
    t.onclick=()=>{
      current=parseInt(t.dataset.index);
      updateSlider(current);
    }
  });

  function closePop(){
    popup.classList.remove("active");
    document.body.classList.remove("lx-lock");
  }

  closeBtn.onclick=closePop;
  overlay.onclick=closePop;

});
</script>

{% schema %}
{
  "name": "Custom Gallery Lightbox",
  "settings": [
    {
      "type": "text",
      "id": "hed",
      "label": "Heading",
      "default": "Lashe Gallery"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Desktop Columns",
      "options": [
        { "value": "3", "label": "3 Columns" },
        { "value": "4", "label": "4 Columns" }
      ],
      "default": "4"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        { "type": "image_picker", "id": "img", "label": "Image" }
      ]
    }
  ],
  "presets": [
    { 
      "name": "Custom Gallery Lightbox",
      "category": "Custom"
    }
  ]
}
{% endschema %}