
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="koc-stats section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{%- render 'spacing-padding', settings: section.settings -%}; --koc-stat-accent: {{ section.settings.accent_color }};"
>
  {%- if section.settings.heading != blank -%}
    <div class="koc-stats__header">
      <h2 class="koc-stats__heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="koc-stats__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="koc-stats__grid">
    {%- for block in section.blocks -%}
      <div class="koc-stats__item" data-animate {{ block.shopify_attributes }}>
        {%- if block.settings.icon != blank -%}
          <div class="koc-stats__icon" aria-hidden="true">{{ block.settings.icon }}</div>
        {%- endif -%}
        <div class="koc-stats__number">{{ block.settings.number | escape }}</div>
        <div class="koc-stats__label">{{ block.settings.label | escape }}</div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.koc-stats {
  text-align: center;
}

.koc-stats__header {
  margin-bottom: 40px;
}

.koc-stats__heading {
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 700;
  margin-bottom: 8px;
}

.koc-stats__subheading {
  font-size: 0.9rem;
  opacity: 0.65;
}

/* Grid: 2-col on mobile, 4-col desktop */
.koc-stats__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}

@media screen and (min-width: 750px) {
  .koc-stats__grid {
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0;
  }
}

.koc-stats__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 28px 16px;
  position: relative;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}

.koc-stats__item.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* Staggered animation delay per item */
.koc-stats__item:nth-child(1) { transition-delay: 0s; }
.koc-stats__item:nth-child(2) { transition-delay: 0.1s; }
.koc-stats__item:nth-child(3) { transition-delay: 0.2s; }
.koc-stats__item:nth-child(4) { transition-delay: 0.3s; }
.koc-stats__item:nth-child(5) { transition-delay: 0.4s; }
.koc-stats__item:nth-child(6) { transition-delay: 0.5s; }

/* Vertical divider between items on desktop */
@media screen and (min-width: 750px) {
  .koc-stats__item + .koc-stats__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 25%;
    height: 50%;
    width: 1px;
    background: currentColor;
    opacity: 0.12;
  }
}

.koc-stats__icon {
  font-size: 1.8rem;
  line-height: 1;
  margin-bottom: 4px;
}

.koc-stats__number {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 800;
  color: var(--koc-stat-accent, #b8751b);
  line-height: 1;
  letter-spacing: -0.02em;
}

.koc-stats__label {
  font-size: 0.78rem;
  font-weight: 600;
  opacity: 0.65;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

@media (prefers-reduced-motion: reduce) {
  .koc-stats__item {
    opacity: 1;
    transform: none;
    transition: none;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.2 }
  );

  document
    .querySelectorAll('.koc-stats__item[data-animate]')
    .forEach((el) => observer.observe(el));
})();
{% endjavascript %}

{% schema %}
{
  "name": "Stats bar",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "✨" },
        { "type": "text", "id": "number", "label": "Number", "default": "40,000+", "info": "e.g. 40,000+ or 350K+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Happy Customers" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "color", "id": "accent_color", "label": "Number accent color", "default": "#b8751b" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    {
      "type": "select", "id": "section_width", "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 56 }
  ],
  "presets": [
    {
      "name": "Stats bar",
      "category": "Text",
      "blocks": {
        "stat_1": { "type": "stat", "settings": { "icon": "✨", "number": "40,000+", "label": "Happy Customers" } },
        "stat_2": { "type": "stat", "settings": { "icon": "📸", "number": "350K+", "label": "Instagram Family" } },
        "stat_3": { "type": "stat", "settings": { "icon": "🏪", "number": "10+", "label": "Stores" } },
        "stat_4": { "type": "stat", "settings": { "icon": "🌆", "number": "5", "label": "Cities" } }
      },
      "block_order": ["stat_1","stat_2","stat_3","stat_4"]
    }
  ]
}
{% endschema %}
