
{% liquid
  assign columns = section.settings.columns | default: 3
%}

<section
  class="promo-banner-grid section-{{ section.id }}"
  style="
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --gap: {{ section.settings.grid_gap }}px;
    --card-bg: {{ section.settings.card_bg }};
    --heading-color: {{ section.settings.heading_color }};
    --button-color: {{ section.settings.button_color }};
    --section-bg: {{ section.settings.section_bg }};
  "
>
  <div class="page-width">
    <div class="promo-banner-grid__wrapper columns-{{ columns }}">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="promo-banner-grid__card"
          {{ block.shopify_attributes }}
        >
          <div class="promo-banner-grid__content">

            {% if block.settings.heading != blank %}
              <h3 class="promo-banner-grid__title">{{ block.settings.heading }}</h3>
            {% endif %}

            {% if block.settings.button_label != blank %}
              <span class="promo-banner-grid__button">{{ block.settings.button_label }}</span>
            {% endif %}
          </div>

          <div class="promo-banner-grid__image">
            {% assign desktop_image = block.settings.image %}
            {% assign mobile_image = block.settings.mobile_image | default: block.settings.image %}

            {% if desktop_image != blank %}
              <picture>
                {% if mobile_image != blank %}
                  <source
                    media="(max-width: 767px)"
                    srcset="{{ mobile_image | image_url: width: 800 }}"
                  >
                {% endif %}
                {{
                  desktop_image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '400,600,800,1000,1200',
                    sizes: '(max-width: 767px) 100vw, 33vw',
                    alt: block.settings.heading
                }}
              </picture>
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .promo-banner-grid {
    padding-top: var(--pt);
    padding-bottom: var(--pb);
    background: var(--section-bg);
  }

  .promo-banner-grid__wrapper {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: var(--gap);
  }

  @media screen and (min-width: 768px) {
    .promo-banner-grid__wrapper.columns-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .promo-banner-grid__wrapper.columns-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .promo-banner-grid__wrapper.columns-4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .promo-banner-grid__card {
    position: relative;
    display: flex;
    align-items: stretch;
    min-height: 320px;
    background: var(--card-bg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.35s ease;
  }

  .promo-banner-grid__card:hover {
    transform: translateY(-3px);
  }

  .promo-banner-grid__content {
    width: 48%;
    padding: 38px 24px 38px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .promo-banner-grid__title {
    margin: 0 0 24px;
    color: var(--heading-color);
    font-size:22px;
    line-height: 1.15;
    font-weight: 400;
    max-width: 320px;
  }

  .promo-banner-grid__button {
    color: var(--button-color);
    font-size: 18px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .promo-banner-grid__image {
    width: 52%;
    position: relative;
    overflow: hidden;
  }

  .promo-banner-grid__image img,
  .promo-banner-grid__image svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .promo-banner-grid__card:hover .promo-banner-grid__image img {
    transform: scale(1.05);
  }

  .placeholder-svg {
    width: 100%;
    height: 100%;
    background: #f5f5f5;
  }

  @media screen and (max-width: 767px) {
    .promo-banner-grid__card {
      min-height: auto;
      flex-direction: column;
    }

    .promo-banner-grid__content,
    .promo-banner-grid__image {
      width: 100%;
    }

    .promo-banner-grid__content {
      order: 1;
      padding: 24px 20px;
    }

    .promo-banner-grid__image {
      order: 2;
      aspect-ratio: 4 / 3;
    }

    .promo-banner-grid__title {
      font-size: 30px;
      margin-bottom: 16px;
      max-width: 100%;
    }

    .promo-banner-grid__button {
      font-size: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Promo Banner Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#f4f1ec"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Gold-Plated Handcrafted Hoop Earrings"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Custom Promo Banner Grid",
      "blocks": [
        {
          "type": "banner"
        },
        {
          "type": "banner"
        },
        {
          "type": "banner"
        }
      ]
    }
  ]
}
{% endschema %}
