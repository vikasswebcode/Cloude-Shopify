
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="koc-igcta section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{%- render 'spacing-padding', settings: section.settings -%}"
>
  <div class="koc-igcta__inner">

    {%- if section.settings.eyebrow != blank -%}
      <p class="koc-igcta__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.show_follower_count and section.settings.follower_count != blank -%}
      <p class="koc-igcta__count">{{ section.settings.follower_count | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="koc-igcta__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="koc-igcta__subtext">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}

    {%- if section.settings.handle != blank -%}
      <a
        href="{{ section.settings.instagram_url | default: '#' }}"
        class="koc-igcta__handle"
        target="_blank"
        rel="noopener noreferrer"
      >{{ section.settings.handle | escape }}</a>
    {%- endif -%}

    {%- if section.settings.btn_label != blank -%}
      <div class="koc-igcta__btns">
        <a
          href="{{ section.settings.instagram_url | default: '#' }}"
          class="koc-igcta__btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="{{ section.settings.btn_label | escape }}"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          {{ section.settings.btn_label | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.koc-igcta {
  position: relative;
  overflow: hidden;
}

/* Decorative blurred circles */
.koc-igcta::before,
.koc-igcta::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  opacity: 0.06;
}

.koc-igcta::before {
  width: 360px;
  height: 360px;
  background: radial-gradient(circle, #E1306C, transparent 70%);
  top: -100px;
  right: -80px;
}

.koc-igcta::after {
  width: 280px;
  height: 280px;
  background: radial-gradient(circle, #833AB4, transparent 70%);
  bottom: -80px;
  left: -60px;
}

.koc-igcta__inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 560px;
  margin-inline: auto;
  gap: 4px;
}

.koc-igcta__eyebrow {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #E1306C;
  padding: 4px 14px;
  border: 1.5px solid rgba(225,48,108,0.3);
  border-radius: 100px;
  margin-bottom: 12px;
}

.koc-igcta__count {
  font-size: clamp(3rem, 8vw, 5rem);
  font-weight: 900;
  background: linear-gradient(135deg, #E1306C, #833AB4);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: 6px;
  letter-spacing: -0.03em;
}

.koc-igcta__heading {
  font-size: clamp(1.3rem, 3vw, 1.8rem);
  font-weight: 700;
  margin-bottom: 10px;
  line-height: 1.25;
}

.koc-igcta__subtext {
  font-size: 0.875rem;
  opacity: 0.65;
  line-height: 1.65;
  max-width: 400px;
  margin-bottom: 12px;
}

.koc-igcta__handle {
  font-size: 1.05rem;
  font-weight: 700;
  color: #E1306C;
  text-decoration: none;
  margin-bottom: 20px;
  letter-spacing: 0.02em;
}

.koc-igcta__handle:hover { text-decoration: underline; }

.koc-igcta__btns {
  margin-top: 8px;
}

.koc-igcta__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 28px;
  border-radius: 100px;
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
  color: #ffffff;
  background: linear-gradient(135deg, #E1306C 0%, #833AB4 60%, #405DE6 100%);
  border: none;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  letter-spacing: 0.02em;
}

.koc-igcta__btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(225,48,108,0.35);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Instagram CTA",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "Instagram Community" },
    { "type": "checkbox", "id": "show_follower_count", "label": "Show follower count", "default": true },
    { "type": "text", "id": "follower_count", "label": "Follower count text", "default": "350K+", "info": "e.g. 350K+" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Be Part of Our Family" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Follow us for daily inspiration, behind-the-scenes and new arrivals" },
    { "type": "text", "id": "handle", "label": "Instagram handle", "default": "@kingofcards.in" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Follow on Instagram" },
    { "type": "header", "content": "Layout" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    {
      "type": "select", "id": "section_width", "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [
    {
      "name": "Instagram CTA",
      "category": "Social",
      "settings": {
        "eyebrow": "Instagram Community",
        "follower_count": "350K+",
        "heading": "Be Part of Our Family",
        "handle": "@kingofcards.in",
        "btn_label": "Follow on Instagram"
      }
    }
  ]
}
{% endschema %}
